# ========================================
# PLANTILLA DE VARIABLES DE ENTORNO
# Copia este archivo como .env y configura los valores
# ========================================

# Base de Datos MySQL
DB_NAME=app_rh_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ========================================
# Configuración de Email (SMTP)
# ========================================
# Para Gmail, necesitas generar una "Contraseña de Aplicación":
# 1. Ve a: https://myaccount.google.com/security
# 2. Activa "Verificación en 2 pasos"
# 3. Ve a "Contraseñas de aplicaciones"
# 4. Genera una nueva contraseña para "Correo"
# 5. Copia la contraseña (16 caracteres sin espacios)
# 6. Pégala en EMAIL_HOST_PASSWORD

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_password_de_aplicacion
DEFAULT_FROM_EMAIL=noreply@evaluacion.com

# URL del sitio (para enlaces en correos)
SITE_URL=http://localhost:8000

# ========================================
# EJEMPLO DE CONFIGURACIÓN COMPLETA:
# ========================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=evaluacion@gmail.com
# EMAIL_HOST_PASSWORD=abcdefghijklmnop
# DEFAULT_FROM_EMAIL=evaluacion@gmail.com
# SITE_URL=http://localhost:8000
